{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "React Library",
  "extends": "./base.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",

    "lib": ["DOM", "DOM.Iterable", "ES2022"],

    "jsx": "react-jsx",

    "declaration": true,
    "emitDeclarationOnly": false
  }
}
